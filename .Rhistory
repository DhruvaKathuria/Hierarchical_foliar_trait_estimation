olution_terms(cv_out)[1:12]
solution_terms(cv_out)[1:12]
s1 <- solution_terms(cv_out)[1:12]
which(s1 %in% s1)
which(s1 %in% coln1)
l1 <- which(cor1 > 0.4)
coln1 <- colnames(data_input)[l1]
which(s1 %in% coln1)
l1 <- which(cor1 > 0.2)
coln1 <- colnames(data_input)[l1]
s1 <- solution_terms(cv_out)[1:12]
which(s1 %in% coln1)
l1 <- which(cor1 > 0.15)
s1 <- solution_terms(cv_out)[1:12]
which(s1 %in% coln1)
l1 <- which(cor1 > 0.15)
coln1 <- colnames(data_input)[l1]
s1 <- solution_terms(cv_out)[1:12]
which(s1 %in% coln1)
coln1
rm(cv_out)
gc()
saveRDS(coln1, paste0(macstudio_folder, "/data/code_output_data/terms_for_LMA"))
