data= df,
family= gaussian(),
prior=c(prior(normal(0,0.00001),class="Intercept"),
prior(horseshoe(df = 1, par_ratio = 0.1),class="b")
#prior(normal(0, 0.05),class="b")
),
chains = 1, cores = 1,
backend = "cmdstanr",
#threads = threading(4),
warmup = 1000, iter = 5000,
sample_prior = "only")
