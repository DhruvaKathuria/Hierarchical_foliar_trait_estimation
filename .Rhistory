pivot_longer(cols = c(`bayesian (mean)`,
`bayesian 10th %tile`, `bayesian 90th %tile`),
names_to = "prediction",
values_to = "value")
data_test_pred_projpred_long <- mutate(data_test_pred_projpred_long,
trait_name = trait_name1,
model = "reduced model")
