library(brms)
x <- rnorm(100)
y <- rnorm(100)
df <- data.frame(x = x, y = y)
brms_normal <- brm(y ~ x,
data= df,
family= gaussian(),
prior=c(prior(normal(0,0.0001),class="Intercept"),
prior(horseshoe(df = 1, par_ratio = 1),class="b")
#prior(normal(0, 0.05),class="b")
),
chains = 1, cores = 1,
backend = "cmdstanr",
#threads = threading(4),
warmup = 1000, iter = 5000,
sample_prior = "only")
posterior_predict(brms_normal)
p_out <- posterior_predict(brms_normal)
View(p_out)
