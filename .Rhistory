theme_minimal() +  # Minimal theme for a cleaner look
labs(x = "V1", y = "Spectra Rank")  # Adding labels
# Optional: Remove the legend for size, if it's not needed
p <- p + guides(size = FALSE)
print(p)
data$spectra_rank <- as.numeric(as.character(data$spectra_rank))
# Assuming 'spectra_means' represents a summary metric that can be plotted as a horizontal line
# Calculate the mean of 'spectra_means' for simplicity and visibility
mean_spectra_means <- mean(data$spectra_means, na.rm = TRUE)
# Create the plot
p <- ggplot(data, aes(x = V1)) +
geom_hline(yintercept = mean_spectra_means, color = "green", size = 1.5, alpha = 0.7) +  # Plotting mean 'spectra_means' as a horizontal line
geom_point(aes(y = spectra_rank, size = 31 - spectra_rank)) +  # Point size inversely related to rank
scale_size_continuous(range = c(1, 6)) +  # Adjust size range as needed
facet_wrap(~ trait_name, scales = "free") +  # Faceting by 'trait_name'
scale_y_reverse(breaks = seq(1, 30, by = 1), name = "Spectra Rank") +  # Inverting y-axis for 'spectra_rank'
theme_minimal() +  # Minimal theme for a cleaner look
labs(x = "V1", y = "Spectra Rank")  # Adding labels
# Optional: Adjust the y-axis limits if necessary to ensure visibility
p <- p + ylim(c(1, 30))
# Optional: Remove the legend for size, if it's not needed
p <- p + guides(size = FALSE)
print(p)
data$spectra_rank <- as.numeric(as.character(data$spectra_rank))
# Plot without faceting to simplify troubleshooting
p <- ggplot(data, aes(x = V1)) +
geom_hline(yintercept = mean(data$spectra_means, na.rm = TRUE), color = "green", size = 2, alpha = 1) +  # More visible line
geom_point(aes(y = spectra_rank, size = 31 - spectra_rank)) +  # Point size inversely related to rank
scale_size_continuous(range = c(1, 6)) +  # Adjust size range as needed
scale_y_reverse(breaks = seq(1, 30, by = 1), name = "Spectra Rank") +  # Inverting y-axis for 'spectra_rank'
theme_minimal() +  # Minimal theme for a cleaner look
labs(x = "V1", y = "Spectra Rank")  # Adding labels
# Ensure the y-axis limits include the range of 'spectra_means'
y_limits <- range(c(data$spectra_rank, mean(data$spectra_means, na.rm = TRUE)), na.rm = TRUE)
p <- p + ylim(y_limits)
print(p)
# Ensure 'spectra_rank' and 'spectra_means' are numeric and handle NA values
data$spectra_rank <- as.numeric(as.character(data$spectra_rank))
data$spectra_means <- as.numeric(as.character(data$spectra_means))
# Handle NA values in 'spectra_means' if necessary, for example, by replacing them with the mean
data$spectra_means[is.na(data$spectra_means)] <- mean(data$spectra_means, na.rm = TRUE)
# Check if 'spectra_means' has a valid range for scaling
if(min(data$spectra_means) != max(data$spectra_means)) {
# Scale 'spectra_means' to the range of 'spectra_rank'
data$scaled_spectra_means <- rescale(data$spectra_means, to = range(data$spectra_rank, na.rm = TRUE))
} else {
# Handle the case where 'spectra_means' cannot be scaled normally
# For example, set all scaled values to the midpoint of 'spectra_rank'
data$scaled_spectra_means <- mean(range(data$spectra_rank, na.rm = TRUE))
}
# Create the plot
p <- ggplot(data, aes(x = V1)) +
geom_line(aes(y = scaled_spectra_means), color = "grey", alpha = 0.5) +  # Plotting the scaled means in the background
geom_point(aes(y = spectra_rank, color = spectra_rank)) +  # Plotting the individual data points
facet_wrap(~ trait_name, scales = "free") +  # Faceting by 'trait_name'
scale_y_reverse(breaks = seq(1, 30, by = 1), name = "Spectra Rank") +  # Inverting y-axis for 'spectra_rank'
scale_color_gradient(low = "blue", high = "red") +  # Continuous color scale for 'spectra_rank'
theme_minimal() +  # Minimal theme for a cleaner look
labs(x = "V1", color = "Spectra Rank")  # Adding labels
# Add secondary axis for 'spectra_means' (if needed for clarity)
p <- p + scale_y_continuous(sec.axis = sec_axis(~., name = "Scaled Spectra Means"))
print(p)
