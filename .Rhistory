# formula for brms --------------------------------------------------------
input_x_names <- data_train_for_analysis |>
select(starts_with("x")) |>
colnames()
non_hierarchical_group = paste(input_x_names,
collapse = "+")
formula_for_brms  = paste("trait ~ 1 + ",
non_hierarchical_group,
sep = "")
