),
data= data_train,
k = "loo",
method  = "hatvalues"
)
cv.mse.loo <- sapply(cv_loo, function(x) x[["CV crit"]])
plot(cv.mse.loo, type = "b")
which.main(cv.mse.loo)
which.min(cv.mse.loo)
pls_fit <- plsr(Salary ~ .,
data = train,
scale = T,
center = T,
validation = "LOO")
validationplot(pls_fit, val.type = "MSEP")
RMSE_values_cv = MSEP(pls_fit)
RMSE_values = RMSE_values_cv$val[1, ,]
which.min(RMSE_values)
p1_pred <- predict(pls_fit, test)
plot(p1_pred, test$Salary)
plot(p1_pred[, , 4], test$Salary)
abline(0, 1)
x_test <- test[, -1]
View(x_test)
scores_test <- predict(plsmod,
newdata = x_test,
type = "scores")
View(test)
#x_test <- test[, -1]
scores_test <- predict(plsmod,
newdata = test,
type = "scores")
lm_predict <- lm(test$Salary ~ scores_test[, 1:9])
cv_loo
cv.mse.loo
lm_predict <- predict(m.9, test$Salary ~ scores_test[, 1:8])
lm_predict <- predict(m.9, scores_test)
View(scores_test)
scores_test <- scores_test |> clean_names() |> data.frame()
lm_predict <- predict(m.9, scores_test)
lm_predict <- predict(m.8, scores_test)
plot(lm_predict, test$Salary)
abline(0, 1)
mse_function <- function(m, o) {mean( (o - m)^2 )}
mse_function(lm_predict, test$Salary)
mse_function(p1_pred, test$Salary)
lm_predict <- predict(m.3, scores_test)
plot(lm_predict, test$Salary)
abline(0, 1)
mse_function(lm_predict, test$Salary)
